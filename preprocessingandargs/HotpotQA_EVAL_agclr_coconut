# Evaluation on 500 Samples
# ──────────────────────────────────────────────────────────────────────────────

def evaluate_agclr_epoch11(model, num_samples=500):
    """
    Full evaluation on 500 samples at stage 3 (6 latent tokens).
    Uses same generate_hotpotqa_answer logic as CoT baseline for fair comparison.
    """
    print(f"\n🧪 Running full evaluation on {num_samples} samples...")
    print(f"   Stage: 3 — 6 latent tokens")

    eval_samples = valid_data[:min(num_samples, len(valid_data))]

    results    = []
    em_scores  = []
    f1_scores  = []
    hop_counts = []

    start_time = time.time()
    eval_pbar  = tqdm(eval_samples, desc="AGCLR Epoch 11 Eval", colour="red")

    for idx, sample in enumerate(eval_pbar):
        try:
            question_text  = sample["question"]
            question_input = question_text + "\n### "
            question_tokens = tokenizer.encode(question_input, add_special_tokens=True)

            generated_answer = generate_hotpotqa_answer(
                model, question_tokens, max_new_tokens=30
            )

            gold_answer = sample["answer"]
            hop_count   = sample.get("hop_count", 2)

            em = exact_match(generated_answer, gold_answer)
            f1 = f1_score(generated_answer, gold_answer)

            result = {
                "idx":              idx,
                "question":         question_text[:100] + "...",
                "gold_answer":      gold_answer,
                "generated_answer": generated_answer,
                "exact_match":      em,
                "f1_score":         f1,
                "hop_count":        hop_count,
            }
            results.append(result)

            em_scores.append(em)
            f1_scores.append(f1)
            hop_counts.append(hop_count)

            current_em = sum(em_scores) / len(em_scores)
            current_f1 = sum(f1_scores) / len(f1_scores)
            eval_pbar.set_postfix({
                'EM': f'{current_em:.3f}',
                'F1': f'{current_f1:.3f}',
                'R':  f'{model.gated_concept_stream.last_r:.3f}',
                'F':  f'{model.gated_concept_stream.last_f:.3f}',
                'W':  f'{model.gated_concept_stream.last_w:.3f}',
            })

            if (idx + 1) % 100 == 0:
                print(f"\n📝 Example {idx + 1}:")
                print(f"   Q:    {result['question']}")
                print(f"   Gold: {result['gold_answer']}")
                print(f"   Gen:  {result['generated_answer']}")
                print(f"   EM: {em}  F1: {f1:.3f}  Hops: {hop_count}")

        except Exception as e:
            print(f"⚠️ Error on sample {idx}: {e}")
            continue

    eval_pbar.close()

    overall_em  = sum(em_scores) / len(em_scores) if em_scores else 0
    overall_f1  = sum(f1_scores) / len(f1_scores) if f1_scores else 0
    eval_time   = time.time() - start_time

    return {
        "overall_em":           overall_em,
        "overall_f1":           overall_f1,
        "num_evaluated":        len(em_scores),
        "eval_time_minutes":    eval_time / 60,
        "results":              results,
        "hop_distribution":     {h: hop_counts.count(h) for h in set(hop_counts)},
        "gate_r":               model.gated_concept_stream.last_r,
        "gate_f":               model.gated_concept_stream.last_f,
        "gate_w":               model.gated_concept_stream.last_w,
    }


agclr_e11_results = evaluate_agclr_epoch11(agclr_eval, num_samples=500)

